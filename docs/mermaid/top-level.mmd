flowchart TD
  %% Define the teacher role (for clarity in the diagram)
  subgraph Rol
    U@{ shape: icon, icon: "fa:user", label: "Docente / Evaluador", pos: "t", h: 48 }
  end

  %% Start / Login flow
  Login@{ shape: stadium, label: "Login" } --> Dashboard@{ shape: rect, label: "Dashboard" }
  Dashboard --> PFiltros@{ shape: lean-r, label: "Buscar / Filtrar / Ordenar" }
  Dashboard --> PList@{ shape: rect, label: "Listado de Proyectos" }
  Dashboard --> TList@{ shape: rect, label: "Listado de Tesis" }

  %% Project detail & evaluation (process)
  PList --> PDet@{ shape: subproc, label: "Detalle de Proyecto" }
  PDet --> PEval@{ shape: rect, label: "Evaluar Proyecto" }
  PEval --> PScore@{ shape: rect, label: "Calcular puntaje 0-20" }
  PScore --> PEstado@{ shape: rect, label: "Asignar estado" }
  PEstado --> PRes@{ shape: doc, label: "Resultado mostrado" }

  %% Tesis detail & two-phase evaluation
  TList --> TDet@{ shape: subproc, label: "Detalle de Tesis" }
  TDet --> F1@{ shape: hex, label: "Fase 1" }
  F1 --> Resp1@{ shape: rect, label: "Responder preguntas F1" }
  Resp1 --> Score1@{ shape: rect, label: "Calcular puntaje F1 0-20" }
  Score1 -->|">= 15"| SaveSession@{ shape: lean-l, label: "Guardar pass (sessionStorage demo)" }
  Score1 -->|"< 15"| GateBlock@{ shape: f-circ, label: "Bloqueo: sin acceso a F2" }
  SaveSession --> GatePass@{ shape: rect, label: "Habilitar Fase 2" }
  GatePass --> F2@{ shape: hex, label: "Fase 2" }
  F2 --> Resp2@{ shape: rect, label: "Responder preguntas F2" }
  Resp2 --> Score2@{ shape: rect, label: "Calcular puntaje F2 0-20" }
  Score2 --> TRes@{ shape: doc, label: "Resultado final mostrado" }

  %% Styling
  classDef approved fill:#ECFDF5,stroke:#10B981,color:#065F46;
  classDef pending fill:#FFFBEB,stroke:#D97706,color:#92400E;
  classDef rejected fill:#FEF2F2,stroke:#DC2626,color:#7F1D1D;
  classDef demo fill:#FDF2E9,stroke:#D97706,color:#92400E,stroke-dasharray: 3 2;

  %% Apply classes
  class PRes,TRes approved;
  class PEstado,Score1,Score2 pending;
  class GateBlock rejected;
  class SaveSession demo;
